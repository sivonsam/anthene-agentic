# .env.example — copy to .env and fill in values

# Azure AD B2C
B2C_TENANT_NAME=antheneagentic
B2C_POLICY=B2C_1_signup_signin
B2C_CLIENT_ID=<your-b2c-app-client-id>

# Azure OpenAI / AI Foundry
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Deployment names (defaults to model name if not set)
AZURE_DEPLOYMENT_GPT_4O=gpt-4o
AZURE_DEPLOYMENT_GPT_4O_MINI=gpt-4o-mini

# Azure Cosmos DB
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-primary-key>

# Tool Hub
TOOLHUB_URL=http://anthene-agentic-toolhub:8001

# Telegram (optional, for telegram_notify tool)
TELEGRAM_BOT_TOKEN=<your-bot-token>
TELEGRAM_CHANNEL_ID=<your-channel-id>
